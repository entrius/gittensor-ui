# WebSocket endpoint for Substrate node
VITE_WS_ENDPOINT=ws://127.0.0.1:9945

# Smart contract address (deployed IssueBountyManager)
VITE_CONTRACT_ADDRESS=

# Enable dev mode (uses Alice keyring for signing)
VITE_DEV_MODE=true
